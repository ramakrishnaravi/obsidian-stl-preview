{
  "compilerOptions": {
    "target":           "ES2018",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2018", "DOM"],
    "strict":           true,
    "noImplicitAny":    true,
    "outDir":           ".",
    "rootDir":          "src",
    "inlineSourceMap":  true,
    "inlineSources":    true
  },
  "include": ["src"]
}
